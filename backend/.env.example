FLASK_HOST=0.0.0.0
FLASK_PORT=7000

# URL pública del frontend (para links en emails y redirecciones de verificación)
FRONTEND_URL=https://app.aquantialab.com

# SMTP — servidor Gestia / aquantialab.com
# Puerto 587 + STARTTLS (recomendado) o 465 + SSL (SMTP_USE_SSL=1)
SMTP_HOST=mail.aquantialab.com
SMTP_PORT=587
SMTP_USE_SSL=0
SMTP_USER=no-reply@aquantialab.com
SMTP_PASSWORD=cambia_esto
SMTP_FROM=Aquantia <no-reply@aquantialab.com>

# PostgreSQL / TimescaleDB
PG_HOST=timescaledb
PG_PORT=5432
PG_DB=aquantia
PG_USER=aquantia
PG_PASS=cambia_esto

# MQTT — broker Mosquitto (VPS via TLS o localhost para testing)
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER=backend
MQTT_PASSWORD=cambia_esto
# Pon MQTT_TLS=1 y ajusta MQTT_CA_CERT para conectar al VPS por 8883
MQTT_TLS=0
MQTT_CA_CERT=
